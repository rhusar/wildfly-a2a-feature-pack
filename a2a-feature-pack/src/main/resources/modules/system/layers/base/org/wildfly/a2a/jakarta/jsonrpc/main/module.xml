<module xmlns="urn:jboss:module:1.9" name="org.wildfly.a2a.jakarta.jsonrpc">

    <properties>
        <property name="jboss.api" value="private"/>
    </properties>

    <resources>
        <artifact name="${org.wildfly.a2a:a2a-java-sdk-jakarta-jsonrpc}"/>
    </resources>

    <dependencies>
        <module name="jakarta.enterprise.api"/>
        <module name="jakarta.inject.api"/>
        <module name="jakarta.servlet.api"/>
        <module name="jakarta.ws.rs.api"/>

        <module name="com.google.code.gson"/>
        <module name="com.google.guava"/>
        <module name="com.google.protobuf"/>
        <module name="org.a2aproject.sdk.common"/>
        <module name="org.a2aproject.sdk.jsonrpc-common"/>
        <module name="org.a2aproject.sdk.server-common"/>
        <module name="org.a2aproject.sdk.spec"/>
        <module name="org.a2aproject.sdk.spec-grpc"/>
        <module name="org.a2aproject.sdk.transport.jsonrpc"/>
        <module name="org.slf4j"/>
    </dependencies>
</module>
