<layer-spec xmlns="urn:jboss:galleon:layer-spec:2.0" name="a2a">
    <props>
        <prop name="org.wildfly.category" value="A2A"/>
        <prop name="org.wildfly.description" value="Support for A2A (Agent-to-Agent) Protocol"/>
        <prop name="org.wildfly.stability" value="experimental"/>
    </props>
    <feature spec="subsystem.a2a"/>
    <packages>
        <!-- Subsystem module -->
        <package name="org.wildfly.extension.a2a"/>
        <package name="org.wildfly.extension.a2a.injection"/>
        <!-- A2A SDK core modules -->
        <package name="io.github.a2asdk.common"/>
        <package name="io.github.a2asdk.spec"/>
        <package name="io.github.a2asdk.spec-grpc"/>
        <package name="io.github.a2asdk.jsonrpc-common"/>
        <package name="io.github.a2asdk.http-client"/>
        <package name="io.github.a2asdk.server-common"/>
        <!-- A2A SDK client modules -->
        <package name="io.github.a2asdk.client"/>
        <package name="io.github.a2asdk.client-transport-spi"/>
        <package name="io.github.a2asdk.client-transport-jsonrpc"/>
        <package name="io.github.a2asdk.client-transport-grpc"/>
        <package name="io.github.a2asdk.client-transport-rest"/>
        <!-- Third-party dependencies -->
        <!-- For layers that do NOT bring in the GRPC feature pack with an updated protobuf version -->
        <!-- we need to bring an up-to-date one ourselves, since WildFly uses a very old and incompatible version -->
        <!-- TODO remove once WildFly catches up -->
        <package name="com.google.protobuf"/>
    </packages>
</layer-spec>
